{
  "name": "smartresponsor/tag",
  "type": "library",
  "license": "proprietary",
  "description": "Smartresponsor canonical tagging component library.",
  "require": {
    "php": "^8.2",
    "ext-pdo": "*",
    "ext-curl": "*",
    "ext-mbstring": "*",
    "ext-ctype": "*",
    "ext-intl": "*"
  },
  "require-dev": {
    "doctrine/doctrine-fixtures-bundle": "^3.6",
    "doctrine/doctrine-migrations-bundle": "^3.4",
    "friendsofphp/php-cs-fixer": "^3.94",
    "phpmd/phpmd": "^2.15",
    "phpstan/phpstan": "^1.12",
    "phpunit/phpunit": "^10.5"
    },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "lint": "find src tests host-minimal tools -name \"*.php\" -print0 | xargs -0 -n1 php -l",
    "lint:admin": "node --check admin/app.js",
    "fixture:validate": "php tools/seed/tag-fixture-validate.php",
    "audit:surface": "php tools/audit/tag-surface-audit.php",
    "audit:contract": "php tools/audit/tag-contract-audit.php",
    "audit:route": "php tools/audit/tag-route-controller-audit.php",
    "audit:bootstrap": "php tools/audit/tag-bootstrap-audit.php",
    "audit:bootstrap-runtime": "php tools/audit/tag-bootstrap-runtime-audit.php",
    "audit:config": "php tools/audit/tag-config-audit.php",
    "audit:sdk": "php tools/audit/tag-sdk-audit.php",
    "audit:version": "php tools/audit/tag-version-audit.php",
    "release:preflight": "php tools/release/tag-preflight.php",
    "db:migrate": "php tools/db/tag-migrate.php",
    "db:smoke": "bash tools/db/tag-migration-smoke.sh",
    "demo:seed": "php tools/seed/tag-seed.php",
    "demo:clear": "php tools/seed/tag-clear.php",
    "smoke:runtime": "php tools/smoke/tag-smoke.php",
    "audit:canonical-stale": "php tools/audit/tag-canonical-stale-reference-audit.php",
    "audit:canonical-structure": "php tools/audit/tag-canonical-structure-audit.php",
    "audit:ci": "composer run -n audit:composer-integrity && composer run -n audit:surface && composer run -n audit:contract && composer run -n audit:route && composer run -n audit:bootstrap && composer run -n audit:bootstrap-runtime && composer run -n audit:config && composer run -n audit:sdk && composer run -n audit:version && composer run -n audit:core-boundary && composer run -n audit:canonical-stale && composer run -n audit:canonical-structure && composer run -n audit:repo-hygiene && composer run -n audit:snapshot-purity && composer run -n audit:repo-map-truth && composer run -n audit:ci-workflow && composer run -n audit:demo-truth-pack && composer run -n audit:release-grade-portrait && composer run -n test:unit",
    "audit:composer-integrity": "php tools/audit/tag-composer-integrity-audit.php",
    "test": "vendor/bin/phpunit --testsuite unit",
    "test:unit": "vendor/bin/phpunit --testsuite unit",
    "test:integration": "vendor/bin/phpunit --testsuite integration",
    "gate:install-test": "composer validate --no-interaction --strict && composer run -n audit:composer-integrity && composer run -n test:unit",
    "audit:repo-hygiene": "php tools/audit/tag-repo-hygiene-audit.php",
    "audit:snapshot-purity": "php tools/audit/tag-snapshot-purity-audit.php",
    "audit:repo-map-truth": "php tools/audit/tag-repo-map-truth-audit.php",
    "audit:ci-workflow": "php tools/audit/tag-ci-workflow-audit.php",
    "test:all": "vendor/bin/phpunit",
    "audit:core-boundary": "php tools/audit/tag-core-boundary-audit.php",
    "audit:demo-truth-pack": "php tools/audit/tag-demo-truth-pack-audit.php",
    "audit:release-grade-portrait": "php tools/audit/tag-release-grade-portrait-audit.php",
    "cli:tag": "php tools/cli/tag.php help",
    "cli:tag:status": "php tools/cli/tag.php status --pretty",
    "cli:tag:surface": "php tools/cli/tag.php surface --pretty",
    "test:cli": "vendor/bin/phpunit --filter CliCommandLayerTest"
  }
}