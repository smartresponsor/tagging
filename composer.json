{
  "name": "smartresponsor/tag",
  "type": "library",
  "license": "proprietary",
  "description": "Smartresponsor canonical tagging component library.",
  "require": {
    "php": "^8.2",
    "ext-pdo": "*",
    "ext-curl": "*",
    "ext-mbstring": "*",
    "ext-ctype": "*",
    "ext-intl": "*"
  },
  "require-dev": {
    "doctrine/doctrine-fixtures-bundle": "^3.6",
    "doctrine/doctrine-migrations-bundle": "^3.4",
    "friendsofphp/php-cs-fixer": "^3.94",
    "phpmd/phpmd": "^2.15",
    "phpstan/phpstan": "^1.12",
    "phpunit/phpunit": "^10.5",
    "symfony/panther": "^2.2"
    },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "lint": "find src tests host-minimal tools -name \"*.php\" -print0 | xargs -0 -n1 php -l",
    "lint:admin": "node --check admin/app.js",
    "phpstan": "vendor/bin/phpstan analyse -c phpstan.neon.dist --memory-limit=512M",
    "cs:check": "vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.dist.php --dry-run --diff --using-cache=no",
    "cs:fix": "vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.dist.php --using-cache=no",
    "fixture:validate": "php tools/seed/tag-fixture-validate.php",
    "fixture:dry-run": "php tools/seed/tag-fixture-dry-run.php",
    "docs:openapi:publish": "php tools/release/tag-openapi-publish.php",
    "audit:surface": "php tools/audit/tag-surface-audit.php",
    "audit:contract": "php tools/audit/tag-contract-audit.php",
    "audit:route": "php tools/audit/tag-route-controller-audit.php",
    "audit:bootstrap": "php tools/audit/tag-bootstrap-audit.php",
    "audit:bootstrap-runtime": "php tools/audit/tag-bootstrap-runtime-audit.php",
    "audit:config": "php tools/audit/tag-config-audit.php",
    "audit:sdk": "php tools/audit/tag-sdk-audit.php",
    "audit:version": "php tools/audit/tag-version-audit.php",
    "audit:release-assets": "php tools/audit/tag-release-assets-audit.php",
    "audit:openapi-semantics": "php tools/audit/tag-openapi-semantics-audit.php",
    "audit:generated-openapi-surface": "php tools/audit/tag-generated-openapi-surface-audit.php",
    "audit:antora-surface": "php tools/audit/tag-antora-surface-audit.php",
    "release:preflight": "php tools/release/tag-preflight.php",
    "db:migrate": "php tools/db/tag-migrate.php",
    "db:smoke": "bash tools/db/tag-migration-smoke.sh",
    "db:test:start": "bash tools/test-db-start.sh",
    "db:test:stop": "bash tools/test-db-stop.sh",
    "db:smoke:self-contained": "bash tools/migration-smoke.sh",
    "demo:seed": "php tools/seed/tag-seed.php",
    "demo:clear": "php tools/seed/tag-clear.php",
    "smoke:runtime": "php tools/smoke/tag-smoke.php",
    "audit:canonical-stale": "php tools/audit/tag-canonical-stale-reference-audit.php",
    "audit:canonical-structure": "php tools/audit/tag-canonical-structure-audit.php",
    "audit:ci": "composer run -n audit:composer-integrity && composer run -n audit:surface && composer run -n audit:contract && composer run -n audit:route && composer run -n audit:bootstrap && composer run -n audit:bootstrap-runtime && composer run -n audit:config && composer run -n audit:sdk && composer run -n audit:version && composer run -n audit:release-assets && composer run -n audit:openapi-semantics && composer run -n audit:generated-openapi-surface && composer run -n audit:antora-surface && composer run -n audit:core-boundary && composer run -n audit:canonical-stale && composer run -n audit:canonical-structure && composer run -n audit:repo-hygiene && composer run -n audit:snapshot-purity && composer run -n audit:repo-map-truth && composer run -n audit:ci-workflow && composer run -n audit:demo-truth-pack && composer run -n audit:release-grade-portrait && composer run -n test:unit",
    "audit:composer-integrity": "php tools/audit/tag-composer-integrity-audit.php",
    "test": "vendor/bin/phpunit --testsuite unit",
    "test:unit": "vendor/bin/phpunit --testsuite unit",
    "test:integration": "vendor/bin/phpunit --testsuite integration",
    "test:panther": "sh -lc 'if command -v chromium >/dev/null 2>&1; then export PANTHER_CHROME_BINARY=$(command -v chromium); elif command -v chromium-browser >/dev/null 2>&1; then export PANTHER_CHROME_BINARY=$(command -v chromium-browser); elif command -v google-chrome >/dev/null 2>&1; then export PANTHER_CHROME_BINARY=$(command -v google-chrome); fi; export PANTHER_CHROME_ARGUMENTS=\"--headless=new --disable-dev-shm-usage --no-sandbox\"; vendor/bin/phpunit --testsuite panther'",
    "test:e2e": "npx playwright test",
    "test:e2e:install": "npx playwright install chromium",
    "doctor:php-ext": "bash tools/local/php-extension-doctor.sh",
    "symfony:server:start": "bash tools/local/symfony-server-start.sh",
    "host:test-db:serve": "bash tools/local/tag-serve-test-db.sh",
    "gate:install-test": "composer validate --no-interaction --strict && composer run -n audit:composer-integrity && composer run -n test:unit",
    "audit:repo-hygiene": "php tools/audit/tag-repo-hygiene-audit.php",
    "audit:snapshot-purity": "php tools/audit/tag-snapshot-purity-audit.php",
    "audit:repo-map-truth": "php tools/audit/tag-repo-map-truth-audit.php",
    "audit:ci-workflow": "php tools/audit/tag-ci-workflow-audit.php",
    "test:all": "vendor/bin/phpunit",
    "audit:core-boundary": "php tools/audit/tag-core-boundary-audit.php",
    "audit:demo-truth-pack": "php tools/audit/tag-demo-truth-pack-audit.php",
    "audit:release-grade-portrait": "php tools/audit/tag-release-grade-portrait-audit.php",
    "cli:tag": "php tools/cli/tag.php help",
    "cli:tag:status": "php tools/cli/tag.php status --pretty",
    "cli:tag:surface": "php tools/cli/tag.php surface --pretty",
    "test:cli": "vendor/bin/phpunit --filter CliCommandLayerTest"
  }
}
